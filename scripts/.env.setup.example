# Copy this file to scripts/.env.setup and fill in your values, then run scripts/setup.ps1.
# scripts/.env.setup is gitignored and must never be committed.
#
# NOTE: ANTHROPIC_API_KEY is intentionally NOT in this file. You set it yourself (see README).

# --- GitHub Actions secrets (pushed to the repo by setup.ps1) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Target Slack channel ID (kept as a secret so it is not exposed in public source).
SLACK_CHANNEL_ID=C0XXXXXXXXX
SUPABASE_DB_HOST=db.YOUR-PROJECT-REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password

# --- Supabase project / Edge Function (used by setup.ps1) ---
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF
# Full connection string used to apply db/schema.sql via psql (optional if you apply it in the SQL editor).
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.YOUR-PROJECT-REF.supabase.co:5432/postgres?sslmode=require
# Function secrets (set as Supabase secrets, NOT GitHub secrets):
SLACK_SIGNING_SECRET=your-slack-signing-secret
# Fine-grained PAT for repository_dispatch. Required repository permission: Contents read/write.
GH_DISPATCH_TOKEN=github_pat_xxx_least_privilege_contents_write_for_dispatch

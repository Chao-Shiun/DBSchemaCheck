# Copy this file to scripts/.env.setup and fill in your values, then run scripts/setup.ps1.
# scripts/.env.setup is gitignored and must never be committed.
#
# Claude auth is intentionally not stored here. Set CLAUDE_CODE_OAUTH_TOKEN in CI secrets or Bitbucket repository variables.

# --- Shared Slack / Supabase values ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXXX
SUPABASE_DB_HOST=db.YOUR-PROJECT-REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password

# --- Supabase project / Edge Function ---
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF
# Full connection string used to apply db/schema.sql via psql. Leave blank if you apply it in the SQL editor.
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.YOUR-PROJECT-REF.supabase.co:5432/postgres?sslmode=require
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Required for Bitbucket Slack approval, which is the primary approval flow.
BITBUCKET_API_USERNAME=
BITBUCKET_API_TOKEN=
DEFAULT_SCM_PROVIDER=bitbucket

# Required only for legacy GitHub Slack approval.
GH_DISPATCH_TOKEN=

# Optional comma-separated Slack user IDs allowed to approve/reject warnings.
APPROVER_SLACK_IDS=
